# ─── Application ────────────────────────────────────────
APP_NAME=Zentra
ENVIRONMENT=development          # development | staging | production
DEBUG=true
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32
ALLOWED_HOSTS=["*"]              # Production'da: ["https://dashboard.zentra.uz"] kabi aniq domen(lar)
API_V1_PREFIX=/api/v1

# ─── Database ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=zentra
POSTGRES_USER=zentra
POSTGRES_PASSWORD=zentra_secret
DATABASE_URL=postgresql+asyncpg://zentra:zentra_secret@localhost:5432/zentra
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0
REDIS_CACHE_TTL=3600            # 1 soat

# ─── Auth ────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Telegram ────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
WEBHOOK_URL=https://yourdomain.com/webhook
WEBHOOK_SECRET=your_webhook_secret

# ─── AI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-...    # Kelajak uchun
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.1              # Buxgalteriya uchun past temperatura

# ─── File Storage ────────────────────────────────────────
STORAGE_BACKEND=local           # local | s3 | minio
STORAGE_LOCAL_PATH=./uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=zentra-files
AWS_REGION=us-east-1
MINIO_URL=                      # MinIO bo'lsa: http://localhost:9000 (S3 bo'lsa bo'sh qoldiring)

# ─── Document Generation (PDF) ───────────────────────────
# O'zbekcha tutuq belgisi (o', g') to'g'ri chiqishi uchun Unicode TTF shrift.
# Bo'sh qoldirilsa, standart Helvetica ishlatiladi.
PDF_FONT_PATH=
PDF_FONT_BOLD_PATH=

# ─── Email ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@zentra.uz
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=Zentra <noreply@zentra.uz>

# ─── SMS (Eskiz.uz) ──────────────────────────────────────
ESKIZ_EMAIL=your@email.com
ESKIZ_PASSWORD=your_eskiz_password
ESKIZ_FROM=4546                 # Sender nomi

# ─── Sentry (Error tracking) ─────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ─── Celery ──────────────────────────────────────────────
CELERY_BROKER_URL=redis://:redis_secret@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secret@localhost:6379/2
